Sign is method(value as float) as float {
  if(value < 0) {
    return -1;
  }
  if(value > 0) {
    return 1;
  }
  return 0;
}

Square is method(value as float) as float {
  return value * value;
}

Cube is method(value as float) as float {
  return value * value * value;
}

Inverse is method(value as float) as float {
  return 1 / value;
}
