{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Neuron++",
    "scopeName": "source.npp",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#multiword-keywords"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#identifiers"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.npp",
                    "match": "//.*"
                },
                {
                    "name": "comment.block.npp",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.npp",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.npp",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "multiword-keywords": {
            "patterns": [
                {
                    "name": "keyword.other.npp",
                    "match": "\\b(address of|value of)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.npp",
                    "match": "\\b(if|else|switch|case|default|while|for|break|continue|return|try|catch|finally|throw|async|await|parallel|in)\\b"
                },
                {
                    "name": "keyword.declaration.npp",
                    "match": "\\b(method|class|constructor|module|macro|extern|shader)\\b"
                },
                {
                    "name": "keyword.other.npp",
                    "match": "\\b(is|another|as|then|maybe|move|inherits|this|public|private|thread|atomic|gpu|canvas|pass|unsafe|const|constexpr|typeof|static_assert)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.npp",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.numeric.float.npp",
                    "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?f?\\b"
                },
                {
                    "name": "constant.numeric.integer.npp",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "entity.name.function.npp",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\()"
                },
                {
                    "name": "variable.other.npp",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arithmetic.npp",
                    "match": "\\+|\\-|\\*|/|@|\\+\\+|\\-\\-"
                },
                {
                    "name": "keyword.operator.comparison.npp",
                    "match": "==|!=|>=|<=|>|<"
                },
                {
                    "name": "keyword.operator.logical.npp",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.assignment.npp",
                    "match": "is"
                }
            ]
        }
    }
}
